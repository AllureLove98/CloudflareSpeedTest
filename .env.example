# Cloudflare SpeedTest Docker 配置文件
# 复制为 .env 文件使用

# ===== 基本测速参数 =====
# 延迟测速线程数 (1-1000, 默认200)
CFST_THREADS=200

# 单个IP延迟测速次数 (默认4)
CFST_TIMES=4

# 下载测速IP数量 (默认10)
CFST_DOWNLOAD_THREADS=10

# 单个IP下载测速最长时间(秒) (默认10)
CFST_DOWNLOAD_TIME=10

# 测速端口 (默认443)
CFST_PORT=443

# 测速模式: tcping 或 httping (默认tcping)
CFST_MODE=tcping

# ===== 结果过滤条件 =====
# 平均延迟上限(ms) (默认200)
CFST_MAX_LATENCY=200

# 平均延迟下限(ms) (默认0)
CFST_MIN_LATENCY=0

# 丢包率上限 (0.0-1.0, 默认1.0)
CFST_MAX_LOSS_RATE=1.0

# 下载速度下限(MB/s) (默认0)
CFST_MIN_SPEED=0

# ===== 输出配置 =====
# 显示结果数量 (默认10)
CFST_RESULTS=10

# 输出文件名 (默认result.csv)
CFST_OUTPUT_FILE=result.csv

# ===== Gist 上传配置 =====
# 是否上传结果到GitHub Gist (true/false, 默认false)
CFST_UPLOAD_GIST=false

# GitHub Personal Access Token (需要 gist 权限)
# 获取方式: https://github.com/settings/tokens
GIST_TOKEN=

# Gist 文件名 (默认cloudflare_speedtest_result.csv)
GIST_FILENAME=cloudflare_speedtest_result.csv

# GitHub Gist ID (如果为空则创建新的Gist, 否则更新现有Gist)
GIST_ID=

# ===== 高级参数 =====
# IP数据文件 (相对于容器的/app/ip_data目录)
# CFST_IP_FILE=ip.txt

# 直接指定IP段 (英文逗号分隔)
# CFST_IP_LIST=1.1.1.1,2.2.2.2/24,2606:4700::/32

# 其他命令行参数 (如 -allip -dd 等)
CFST_EXTRA_ARGS=

# 调试模式 (true/false)
CFST_DEBUG=false
