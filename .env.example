# Cloudflare SpeedTest Docker 配置文件
# 使用方法: cp .env.example .env 然后编辑 .env 文件

# ===== 基本测速参数 =====
# 延迟测速线程数 (1-1000, 默认200)
THREADS=200

# 单个IP延迟测速次数 (默认4)
TIMES=4

# 下载测速IP数量 (默认10)
DOWNLOAD_NUM=10

# 单个IP下载测速最长时间(秒) (默认10)
DOWNLOAD_TIME=10

# 测速端口 (默认443)
TEST_PORT=443

# 测速地址 (默认https://cf.xiu2.xyz/url)
TEST_URL=https://cf.xiu2.xyz/url

# ===== 测速模式 =====
# 是否使用 HTTPing 模式 (true/false, 默认false 使用 TCPing)
USE_HTTPING=false

# HTTPing 有效状态码 (默认200)
HTTPING_CODE=200

# 指定地区 (IATA 码，英文逗号分隔，仅 HTTPing 模式可用)
# CF_COLO=HKG,KHH,NRT,LAX

# ===== 结果过滤条件 =====
# 延迟上限(ms) (默认9999)
MAX_DELAY=9999

# 延迟下限(ms) (默认0)
MIN_DELAY=0

# 丢包率上限 (0.0-1.0, 默认1.00)
MAX_LOSS_RATE=1.00

# 下载速度下限(MB/s) (默认0)
MIN_SPEED=0

# ===== 输出配置 =====
# 显示结果数量 (默认10, 0 = 不显示)
RESULT_NUM=10

# 输出文件名 (默认result.csv, 保存到 results/ 目录)
OUTPUT_FILE=result.csv

# 禁用下载测速 (true/false, 默认false)
DISABLE_DOWNLOAD=false

# 测速全部IP (true/false, 默认false)
TEST_ALL_IPS=false

# ===== GitHub Gist 上传配置 =====
# GitHub Personal Access Token (需要 gist 权限)
# 获取方式: https://github.com/settings/tokens
# 不填则不上传
GIST_TOKEN=

# Gist ID (可选，不填则创建新 Gist，填入则更新现有 Gist)
# GIST_ID=

# ===== 其他参数 =====
# IP 文件路径 (默认ip.txt)
# IP_FILE=ip.txt

# 调试模式 (true/false, 默认false)
DEBUG=false

# Gist 文件名 (默认cloudflare_speedtest_result.csv)
GIST_FILENAME=cloudflare_speedtest_result.csv

# GitHub Gist ID (如果为空则创建新的Gist, 否则更新现有Gist)
GIST_ID=

# ===== 高级参数 =====
# IP数据文件 (相对于容器的/app/ip_data目录)
# CFST_IP_FILE=ip.txt

# 直接指定IP段 (英文逗号分隔)
# CFST_IP_LIST=1.1.1.1,2.2.2.2/24,2606:4700::/32

# 其他命令行参数 (如 -allip -dd 等)
CFST_EXTRA_ARGS=

# 调试模式 (true/false)
CFST_DEBUG=false
